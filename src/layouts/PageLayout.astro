---
/**
 * PageLayout — wraps content with Header + Footer.
 * Use this for all regular pages.
 */
import BaseLayout from './BaseLayout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  ogImage?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    min-height: 60vh;
  }
</style>