---
/**
 * Footer — site-wide footer with brand, nav columns, copyright.
 */
import Logo from './Logo.astro';
import { SITE } from '~/consts';

const year = new Date().getFullYear();

const productLinks = [
  { href: '/models', label: 'Models' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/zealot', label: 'Engine' },
  { href: '/docs', label: 'Docs' },
  { href: '/changelog', label: 'Changelog' },
];

const companyLinks = [
  { href: '/contact', label: 'Request access' },
  { href: '/status', label: 'Status' },
  { href: SITE.consoleUrl, label: 'Sign in to Console' },
  { href: SITE.github, label: 'GitHub', external: true },
];

const legalLinks = [
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div class="brand">
        <a href="/" class="logo-link">
          <Logo variant="default" size={28} />
          <span class="wordmark">Ultralisk</span>
        </a>
        <p class="tagline">Open-source LLMs. OpenAI-compatible. Pay per token.</p>
        <p class="contact">
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
      </div>

      <div class="col">
        <h4>Product</h4>
        <ul>
          {
            productLinks.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col">
        <h4>Company</h4>
        <ul>
          {
            companyLinks.map((l) => (
              <li>
                <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col">
        <h4>Legal</h4>
        <ul>
          {
            legalLinks.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="bottom">
      <p>© {year} Ultralisk. All rights reserved.</p>
      <a href="/status" class="status">
        <span class="dot" aria-hidden="true"></span>
        All systems operational
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  @media (max-width: 880px) {
    .grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .brand .logo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    font-size: var(--text-base);
  }

  .wordmark {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .tagline {
    margin-top: var(--space-3);
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    max-width: 28ch;
  }

  .contact {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }

  .contact a {
    color: var(--color-fg);
    border-bottom: 1px dotted var(--color-border-strong);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .contact a:hover {
    border-color: var(--color-accent);
  }

  h4 {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-subtle);
    margin-bottom: var(--space-3);
  }

  .col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .col a {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .col a:hover {
    color: var(--color-fg);
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .status:hover {
    color: var(--color-fg);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
  }
</style>