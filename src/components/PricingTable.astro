---
/**
 * PricingTable — endpoint tiers table.
 */
import { TIERS } from '~/data/pricing';
import { AVAILABLE_MODELS, formatPrice } from '~/data/models';

const isAvailable = (phase: number) => phase <= 1;
---

<section class="pricing-table-section">
  <div class="tiers">
    {
      TIERS.map((tier) => (
        <article class={`tier ${isAvailable(tier.phase) ? '' : 'soon'}`}>
          <header>
            <div class="row">
              <h3>{tier.name}</h3>
              {isAvailable(tier.phase) ? (
                <span class="badge available">Available</span>
              ) : (
                <span class="badge phase">Phase {tier.phase}</span>
              )}
            </div>
            <p class="muted">{tier.description}</p>
          </header>
          <div class="price-row">
            {tier.priceMultiplier ? (
              <span class="big">{Math.round((1 - tier.priceMultiplier) * 100)}% off</span>
            ) : tier.kind === 'reserved' || tier.kind === 'dedicated' ? (
              <span class="big">Custom</span>
            ) : (
              <span class="big">Pay per token</span>
            )}
            <span class="unit">list prices below</span>
          </div>
        </article>
      ))
    }
  </div>

  <div class="model-table-wrapper">
    <table class="model-table">
      <thead>
        <tr>
          <th>Model</th>
          <th>Context</th>
          <th>Serverless<br /><span class="sub">in / out</span></th>
          <th>Batch<br /><span class="sub">in / out (50% off)</span></th>
          <th>Reserved</th>
          <th>Dedicated</th>
        </tr>
      </thead>
      <tbody>
        {
          AVAILABLE_MODELS.map((m) => (
            <tr>
              <td>
                <div class="model-cell">
                  <strong>{m.name}</strong>
                  <span class="vendor">{m.vendor}</span>
                </div>
              </td>
              <td class="num">{m.context.toLocaleString()}</td>
              <td class="num">
                {formatPrice(m.inputPrice)} <span class="dim">/</span> {formatPrice(m.outputPrice)}
              </td>
              <td class="num">
                {formatPrice(m.inputPrice * 0.5)}{' '}
                <span class="dim">/</span> {formatPrice(m.outputPrice * 0.5)}
              </td>
              <td class="muted dim">Contact</td>
              <td class="muted dim">Contact</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <p class="footnote subtle">
    All prices in USD per 1M tokens. Batch pricing applies to async workloads
    with up to 24-hour SLA. Reserved and Dedicated are coming in Phase 2 and 3
    respectively — <a href="/contact">contact us</a> for early access.
  </p>
</section>

<style>
  .pricing-table-section {
    margin-top: var(--space-10);
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  @media (max-width: 880px) {
    .tiers {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .tiers {
      grid-template-columns: 1fr;
    }
  }

  .tier {
    background: var(--color-bg-elevated);
    border: 2px solid var(--color-fg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    box-shadow: var(--shadow-card);
  }

  .tier.soon {
    opacity: 0.65;
  }

  .tier .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }

  .tier h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
  }

  .badge.available {
    background: rgba(31, 162, 94, 0.12);
    color: #1fa25e;
  }

  .badge.phase {
    background: var(--color-bg-subtle);
    color: var(--color-fg-muted);
  }

  .tier p {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .price-row {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .price-row .big {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
  }

  .price-row .unit {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  /* Model table */
  .model-table-wrapper {
    overflow-x: auto;
    border: 2px solid var(--color-fg);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-sm);
  }

  .model-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .model-table thead {
    background: var(--color-bg-subtle);
  }

  .model-table th {
    text-align: left;
    padding: var(--space-4);
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-subtle);
    border-bottom: 2px solid var(--color-fg);
  }

  .model-table th .sub {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-fg-subtle);
  }

  .model-table td {
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .model-table tbody tr:last-child td {
    border-bottom: none;
  }

  .model-table tbody tr:hover {
    background: var(--color-bg-subtle);
  }

  .model-cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .model-cell .vendor {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .dim {
    color: var(--color-fg-subtle);
  }

  .footnote {
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    max-width: 70ch;
  }

  .footnote a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>