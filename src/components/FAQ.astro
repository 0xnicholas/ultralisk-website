---
/**
 * FAQ — accessible disclosure list using <details>/<summary>.
 * No JS required.
 */
import { FAQS } from '~/data/pricing';
---

<section class="faq-section">
  <header class="faq-header">
    <span class="eyebrow">Billing FAQ</span>
    <h2>Common questions</h2>
  </header>

  <div class="faq-list">
    {
      FAQS.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>
            <span>{item.question}</span>
            <span class="chev" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 6l4 4 4-4" />
              </svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-section {
    margin-top: var(--space-16);
  }

  .faq-header {
    margin-bottom: var(--space-8);
  }

  .faq-header h2 {
    margin-top: var(--space-3);
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    letter-spacing: var(--tracking-tight);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq-item {
    border: 2px solid var(--color-fg);
    box-shadow: var(--shadow-sm);
    background: var(--color-bg-elevated);
    overflow: hidden;
    transition: transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .faq-item[open] {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--color-shadow);
  }

  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    font-size: var(--text-base);
    color: var(--color-fg);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .chev {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--color-fg-muted);
    border: 2px solid var(--color-fg-muted);
    transition: transform var(--duration-base) var(--ease-out);
    flex-shrink: 0;
  }

  .faq-item[open] .chev {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 var(--space-5) var(--space-5) var(--space-5);
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }

  .faq-answer p {
    max-width: 70ch;
  }
</style>