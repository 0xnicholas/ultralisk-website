---
/**
 * ModelCard — compact card used on Home preview strip and Models grid.
 */
import type { Model } from '~/data/models';
import { formatPrice, formatContext } from '~/data/models';

export interface Props {
  model: Model;
  /** Compact variant: used on Home preview strip */
  compact?: boolean;
}

const { model, compact = false } = Astro.props;
---

<article class:list={['model-card', 'card', { compact }]}>
  <header>
    <span class="vendor">{model.vendor}</span>
    <h3>{model.name}</h3>
    <p class="tagline muted">{model.tagline}</p>
  </header>

  <dl class="stats">
    <div>
      <dt>Context</dt>
      <dd>{formatContext(model.context)}</dd>
    </div>
    <div>
      <dt>Params</dt>
      <dd>{model.params}B</dd>
    </div>
    <div>
      <dt>Quant</dt>
      <dd>{model.quantization.replace('-', ' ')}</dd>
    </div>
  </dl>

  <footer>
    <div class="price">
      <span class="price-label">In</span>
      <span class="price-value">{formatPrice(model.inputPrice)}</span>
      <span class="price-unit">/ 1M tok</span>
    </div>
    <div class="price">
      <span class="price-label">Out</span>
      <span class="price-value">{formatPrice(model.outputPrice)}</span>
      <span class="price-unit">/ 1M tok</span>
    </div>
  </footer>
</article>

<style>
  .model-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .compact {
    padding: var(--space-5);
    gap: var(--space-4);
  }

  .vendor {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-2);
  }

  h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .tagline {
    margin-top: var(--space-1);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    padding-block: var(--space-4);
    border-top: 2px solid var(--color-fg);
    border-bottom: 2px solid var(--color-fg);
  }

  .stats dt {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: 2px;
  }

  .stats dd {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-fg);
    font-variant-numeric: tabular-nums;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    margin-top: auto;
  }

  .price {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .price-label {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .price-value {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-fg);
    font-variant-numeric: tabular-nums;
  }

  .price-unit {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }
</style>