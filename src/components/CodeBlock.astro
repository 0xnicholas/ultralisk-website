---
/**
 * CodeBlock — renders a tabbed code sample with Shiki highlight.
 * No JS framework needed; uses native radio inputs for tabs.
 *
 * Usage:
 *   <CodeBlock
 *     tabs={[
 *       { label: 'cURL', language: 'bash', code: '...' },
 *       { label: 'Python', language: 'python', code: '...' },
 *     ]}
 *     filename="chat.py"
 *   />
 */
import { Code } from 'astro:components';

export interface CodeTab {
  label: string;
  language: 'bash' | 'python' | 'javascript' | 'typescript' | 'json' | 'text';
  code: string;
}

export interface Props {
  tabs: CodeTab[];
  /** Filename shown in window header */
  filename?: string;
}

const { tabs, filename } = Astro.props;
const id = `cb-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="codeblock" data-tabs={tabs.length}>
  <input
    type="radio"
    name={`tabs-${id}`}
    id={`${id}-0`}
    checked={tabs.length > 0}
    class="tab-input sr-only"
  />
  {
    tabs.slice(1).map((_, i) => (
      <input
        type="radio"
        name={`tabs-${id}`}
        id={`${id}-${i + 1}`}
        class="tab-input sr-only"
      />
    ))
  }

  <div class="window">
    <div class="window-header">
      <div class="dots" aria-hidden="true">
        <span />
        <span />
        <span />
      </div>
      <div class="tabs" role="tablist">
        {
          tabs.map((t, i) => (
            <label for={`${id}-${i}`} class="tab" role="tab">
              {t.label}
            </label>
          ))
        }
      </div>
      {filename && <span class="filename">{filename}</span>}
    </div>

    <div class="panels">
      {
        tabs.map((t, i) => (
          <div class="panel" data-panel={i}>
            <Code code={t.code} lang={t.language} theme="github-dark" />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .codeblock {
    --tab-active-bg: var(--color-bg-elevated);
    position: relative;
  }

  .window {
    background: var(--color-bg-code);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .window-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .dots {
    display: inline-flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border-strong);
  }

  .dots span:nth-child(1) {
    background: #ff5f57;
  }
  .dots span:nth-child(2) {
    background: #febc2e;
  }
  .dots span:nth-child(3) {
    background: #28c840;
  }

  .tabs {
    display: flex;
    gap: 2px;
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .tabs::-webkit-scrollbar {
    display: none;
  }

  .tab {
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-fg-subtle);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .tab:hover {
    color: var(--color-fg);
  }

  .filename {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  .panels {
    position: relative;
  }

  .panel {
    display: none;
  }

  /* Tab activation via CSS */
  .tab-input:nth-of-type(1):checked ~ .window .panel[data-panel='0'],
  .tab-input:nth-of-type(2):checked ~ .window .panel[data-panel='1'],
  .tab-input:nth-of-type(3):checked ~ .window .panel[data-panel='2'],
  .tab-input:nth-of-type(4):checked ~ .window .panel[data-panel='3'] {
    display: block;
  }

  .tab-input:nth-of-type(1):checked ~ .window .tab:nth-of-type(1),
  .tab-input:nth-of-type(2):checked ~ .window .tab:nth-of-type(2),
  .tab-input:nth-of-type(3):checked ~ .window .tab:nth-of-type(3),
  .tab-input:nth-of-type(4):checked ~ .window .tab:nth-of-type(4) {
    background: var(--tab-active-bg);
    color: var(--color-fg);
  }

  /* Shiki output inside panels */
  .panel :global(pre.astro-code) {
    margin: 0;
    border: none;
    border-radius: 0;
    padding: var(--space-6);
    background: var(--color-bg-code) !important;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>