---
/**
 * CTA — call-to-action strip with optional gradient background.
 */
export interface Props {
  heading: string;
  body?: string;
  primary?: { href: string; label: string };
  secondary?: { href: string; label: string };
  /** Use brand gradient background (default true) */
  gradient?: boolean;
}

const {
  heading,
  body,
  primary = { href: '/contact', label: 'Request access' },
  secondary,
  gradient = true,
} = Astro.props;
---

<section class:list={['cta', { gradient }]}>
  <div class="container">
    <div class="inner">
      <h2>{heading}</h2>
      {body && <p>{body}</p>}
      <div class="actions">
        <a href={primary.href} class="btn btn-lg btn-primary">
          {primary.label}
        </a>
        {
          secondary && (
            <a href={secondary.href} class="btn btn-lg btn-secondary">
              {secondary.label}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: clamp(3rem, 8vw, 5rem);
  }

  .gradient {
    background: var(--gradient-glow), var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .inner {
    text-align: center;
    max-width: 56rem;
    margin-inline: auto;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: var(--tracking-tight);
  }

  p {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    max-width: 50ch;
    margin-inline: auto;
  }

  .actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-8);
  }

  .gradient .btn-primary {
    background: var(--gradient-brand);
    color: white;
    border: none;
  }

  .gradient .btn-primary:hover {
    background: var(--gradient-brand);
    filter: brightness(1.1);
    transform: translateY(-1px);
  }
</style>