---
import PageLayout from '~/layouts/PageLayout.astro';
import CodeBlock from '~/components/CodeBlock.astro';
import CTA from '~/components/CTA.astro';
import { MODELS, getModel, formatPrice, formatContext, formatLarge } from '~/data/models';
import { AVAILABLE_MODELS } from '~/data/models';

export function getStaticPaths() {
  return AVAILABLE_MODELS.map((m) => ({ params: { id: m.id }, props: { model: m } }));
}

const { id } = Astro.params;
const model = getModel(id);

// 404 for unknown ids (also handled by getStaticPaths only generating valid ones)
if (!model) {
  return Astro.redirect('/404');
}

// Build tabs for the code block from model.samples
const codeTabs = model.samples.map((s) => ({
  label: s.label,
  language: s.language,
  code: s.code,
}));
---

<PageLayout
  title={`${model.name} — API reference`}
  description={`${model.name} on Ultralisk: ${model.tagline} ${formatContext(model.context)} context, ${formatPrice(model.inputPrice)} in / ${formatPrice(model.outputPrice)} out per 1M tokens.`}
>
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/models">Models</a>
        <span aria-hidden="true">/</span>
        <span class="muted">{model.name}</span>
      </nav>

      <header class="model-header">
        <div class="meta-row">
          <span class="vendor-badge">{model.vendor}</span>
          <span class="family muted">{model.family}</span>
          <span class="dot" aria-hidden="true">·</span>
          <span class="muted">Released {model.released}</span>
        </div>
        <h1>{model.name}</h1>
        <p class="tagline">{model.tagline}</p>
        <p class="description">{model.description}</p>

        <div class="endpoint-row">
          {
            model.endpoints.map((e) => (
              <span class={`endpoint endpoint-${e}`}>
                {e}
                {e === 'batch' && <span class="discount">−50%</span>}
              </span>
            ))
          }
        </div>
      </header>

      <div class="layout">
        <article class="content">
          {/* Pricing */}
          <section class="block">
            <h2>Pricing</h2>
            <div class="price-grid">
              <div class="price-cell">
                <span class="price-label">Input</span>
                <span class="price-value">{formatPrice(model.inputPrice)}</span>
                <span class="price-unit">/ 1M tokens</span>
              </div>
              <div class="price-cell">
                <span class="price-label">Output</span>
                <span class="price-value">{formatPrice(model.outputPrice)}</span>
                <span class="price-unit">/ 1M tokens</span>
              </div>
              <div class="price-cell muted">
                <span class="price-label">Batch</span>
                <span class="price-value">{formatPrice(model.inputPrice * 0.5)} / {formatPrice(model.outputPrice * 0.5)}</span>
                <span class="price-unit">per 1M, 50% off</span>
              </div>
            </div>
          </section>

          {/* API examples */}
          <section class="block">
            <h2>Request examples</h2>
            <p class="muted">
              Point any OpenAI-compatible client at <code>api.ultralisk.io/v1</code>{' '}
              and use <code>{model.id}</code> as the model name.
            </p>
            <div class="code-wrap">
              <CodeBlock tabs={codeTabs} filename={`${model.id.replace(/[^a-z0-9]/gi, '_')}.py`} />
            </div>
          </section>

          {/* Parameters */}
          <section class="block">
            <h2>Parameters</h2>
            <p class="muted">
              Standard OpenAI chat completion parameters. Defaults are tuned for
              general use; tune per workload.
            </p>
            <div class="params-wrap">
              <table class="params">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Default</th>
                    <th>Description</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    model.parameters.map((p) => (
                      <tr>
                        <td>
                          <code>{p.name}</code>
                          {p.required && <span class="req">required</span>}
                        </td>
                        <td class="type">{p.type}</td>
                        <td class="default">{p.default || '—'}</td>
                        <td class="desc">{p.description}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </section>

          {/* Limits */}
          <section class="block">
            <h2>Limits</h2>
            <div class="limits-grid">
              <div class="limit-cell">
                <span class="limit-label">Max output</span>
                <span class="limit-value">{formatLarge(model.limits.maxOutput)}</span>
                <span class="limit-unit">tokens / request</span>
              </div>
              <div class="limit-cell">
                <span class="limit-label">Requests</span>
                <span class="limit-value">{formatLarge(model.limits.requestsPerMinute)}</span>
                <span class="limit-unit">requests / min / key</span>
              </div>
              <div class="limit-cell">
                <span class="limit-label">Tokens</span>
                <span class="limit-value">{formatLarge(model.limits.tokensPerMinute)}</span>
                <span class="limit-unit">tokens / min / key</span>
              </div>
            </div>
            <p class="muted footnote">
              Need higher limits? Reserved endpoints with custom throughput
              launch in Phase 2.{' '}
              <a href="/contact">Contact us</a>.
            </p>
          </section>
        </article>

        {/* Sticky sidebar */}
        <aside class="sidebar">
          <div class="sidebar-card">
            <h3>Quick facts</h3>
            <dl>
              <div><dt>Context</dt><dd>{formatContext(model.context)}</dd></div>
              <div><dt>Parameters</dt><dd>{model.params}B</dd></div>
              <div><dt>Quantization</dt><dd>{model.quantization}</dd></div>
              <div><dt>Backend</dt><dd class="cap">{model.backend}{model.backend === 'vLLM' && <span class="backend-note"> → Zealot in Phase 2</span>}</dd></div>
              <div><dt>Modalities</dt><dd class="cap">{model.modalities.join(', ')}</dd></div>
              <div><dt>Endpoints</dt><dd class="cap">{model.endpoints.join(', ')}</dd></div>
            </dl>
          </div>

          <div class="sidebar-card">
            <h3>Try it</h3>
            <p class="muted">
              Get an API key from the Console and run the examples above.
            </p>
            <a href="https://console.ultralisk.io" class="btn btn-primary sidebar-cta">
              Open Console
            </a>
          </div>

          <div class="sidebar-card related">
            <h3>Other models</h3>
            <ul>
              {
                MODELS.filter((m) => m.available && m.id !== model.id).map((m) => (
                  <li>
                    <a href={`/docs/models/${m.id}`} class="related-link">
                      <span class="related-name">{m.name}</span>
                      <span class="related-meta">{m.params}B · {formatContext(m.context)}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <CTA
    heading={`Ship ${model.name} on Ultralisk`}
    body="Request access to receive an API key with starting credit. Most teams are running their first request within a day."
    primary={{ href: '/contact', label: 'Request access' }}
    secondary={{ href: '/pricing', label: 'See pricing' }}
  />
</PageLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-fg-subtle);
    margin-bottom: var(--space-6);
  }

  .breadcrumb a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .model-header {
    margin-bottom: var(--space-12);
    max-width: 60rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: var(--text-sm);
  }

  .vendor-badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    background: var(--gradient-brand);
    color: white;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
  }

  .family {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .dot {
    color: var(--color-border-strong);
  }

  .model-header h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: var(--tracking-tighter);
    line-height: 1.05;
  }

  .tagline {
    margin-top: var(--space-3);
    font-size: var(--text-xl);
    color: var(--color-fg-muted);
    line-height: var(--leading-snug);
  }

  .description {
    margin-top: var(--space-4);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-fg-muted);
    max-width: 65ch;
  }

  .endpoint-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: var(--space-5);
  }

  .endpoint {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    font-weight: 500;
    font-family: var(--font-mono);
    background: var(--color-bg-subtle);
    color: var(--color-fg-muted);
  }

  .endpoint-serverless {
    color: var(--color-cyan-400);
  }

  [data-theme='light'] .endpoint-serverless {
    color: var(--color-cyan-700);
  }

  .discount {
    color: #22c55e;
    font-weight: 600;
  }

  /* Layout */
  .layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-12);
    align-items: start;
  }

  /* Let grid items shrink so wide tables/code don't expand the page */
  .layout > * {
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  /* Content blocks */
  .block {
    margin-bottom: var(--space-12);
  }

  .block h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-4);
    letter-spacing: var(--tracking-tight);
  }

  .block p {
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
    max-width: 70ch;
    margin-bottom: var(--space-5);
  }

  .block code {
    background: var(--color-bg-code);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.92em;
  }

  .code-wrap {
    margin-top: var(--space-3);
  }

  /* Price grid */
  .price-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  @media (max-width: 720px) {
    .price-grid {
      grid-template-columns: 1fr;
    }
  }

  .price-cell {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg-elevated);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .price-label {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .price-value {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
  }

  .price-unit {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  /* Parameters table */
  .params-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg-elevated);
  }

  .params {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .params thead {
    background: var(--color-bg-subtle);
  }

  .params th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .params td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .params tbody tr:last-child td {
    border-bottom: none;
  }

  .params tbody tr:hover {
    background: var(--color-bg-subtle);
  }

  .params td code {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.92em;
  }

  .params .req {
    margin-left: 0.5rem;
    padding: 0.1rem 0.4rem;
    background: rgba(124, 58, 237, 0.15);
    color: var(--color-accent);
    border-radius: var(--radius-sm);
    font-size: 0.7em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .params .type {
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .params .default {
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .params .desc {
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }

  /* Limits */
  .limits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 720px) {
    .limits-grid {
      grid-template-columns: 1fr;
    }
  }

  .limit-cell {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg-elevated);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .limit-label {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .limit-value {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-fg);
    font-variant-numeric: tabular-nums;
  }

  .limit-unit {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  .footnote {
    margin-top: var(--space-3);
    font-size: var(--text-sm) !important;
  }

  .footnote a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: calc(64px + var(--space-6));
  }

  @media (max-width: 1024px) {
    .sidebar {
      position: static;
    }
  }

  .sidebar-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg-elevated);
  }

  .sidebar-card h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-subtle);
    margin-bottom: var(--space-3);
  }

  .sidebar-card dl {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sidebar-card dl > div {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    font-size: var(--text-sm);
  }

  .sidebar-card dt {
    color: var(--color-fg-subtle);
  }

  .sidebar-card dd {
    font-weight: 500;
    color: var(--color-fg);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .sidebar-card dd.cap {
    text-transform: capitalize;
  }

  .sidebar-card .backend-note {
    display: block;
    text-transform: none;
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    margin-top: 2px;
    font-weight: 400;
  }

  .sidebar-cta {
    display: block;
    text-align: center;
    margin-top: var(--space-3);
    width: 100%;
  }

  .related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .related-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .related-link:hover {
    background: var(--color-bg-subtle);
  }

  .related-name {
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .related-meta {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    font-variant-numeric: tabular-nums;
  }
</style>