---
import PageLayout from '~/layouts/PageLayout.astro';
import FeatureGrid from '~/components/FeatureGrid.astro';
import CodeBlock from '~/components/CodeBlock.astro';
import CTA from '~/components/CTA.astro';
import ModelCard from '~/components/ModelCard.astro';
import { AVAILABLE_MODELS } from '~/data/models';
import { getCollection } from 'astro:content';
import { SITE } from '~/consts';

const latestUpdates = (await getCollection('changelog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const features = [
  {
    icon: 'plug' as const,
    title: 'OpenAI-compatible',
    body: 'Drop-in replacement. Same /v1/chat/completions and /v1/embeddings endpoints, same request and response schemas. Switch by changing the base URL.',
  },
  {
    icon: 'gauge' as const,
    title: 'Token-priced',
    body: 'Pay only for what you use. Per-million-token pricing on input and output. No seats, no commitments, no surprise egress fees.',
  },
  {
    icon: 'eye' as const,
    title: 'GPU-aware',
    body: 'See real utilization, queue depth, and per-model cost attribution in the Console. The same transparency we use to run our own fleet.',
  },
];

const apiExamples = {
  curl: `curl https://api.ultralisk.io/v1/chat/completions \\
  -H "Authorization: Bearer $ULTRALISK_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "meta-llama-3.3-70b-instruct",
    "messages": [
      { "role": "user", "content": "Explain KV cache in 3 sentences." }
    ]
  }'`,
  python: `from openai import OpenAI

client = OpenAI(
    base_url="https://api.ultralisk.io/v1",
    api_key="ULTRALISK_API_KEY",
)

resp = client.chat.completions.create(
    model="meta-llama-3.3-70b-instruct",
    messages=[{"role": "user", "content": "Explain KV cache in 3 sentences."}],
)
print(resp.choices[0].message.content)`,
  streaming: `from openai import OpenAI

client = OpenAI(
    base_url="https://api.ultralisk.io/v1",
    api_key="ULTRALISK_API_KEY",
)

stream = client.chat.completions.create(
    model="meta-llama-3.3-70b-instruct",
    messages=[{"role": "user", "content": "Write a haiku about Rust."}],
    stream=True,
)
for chunk in stream:
    print(chunk.choices[0].delta.content or "", end="")`,
};
---

<PageLayout>
  {/* Hero */}
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <span class="eyebrow">
        <span class="badge">Phase 1 — invitation-only</span>
      </span>
      <h1 class="hero-title">
        Open-source LLMs.<br />
        <span class="gradient-text">OpenAI-compatible API.</span><br />
        Pay per token.
      </h1>
      <p class="hero-sub">
        Ultralisk is an AI inference cloud for open-source large language models.
        Run Llama 3.x with the same SDK you already use, at transparent per-token
        prices — backed by a Rust gateway you can see through.
      </p>
      <div class="hero-actions">
        <a href={SITE.consoleUrl} class="btn btn-lg btn-gradient">
          Open Console
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
        <a href="/docs" class="btn btn-lg btn-secondary">Read the quickstart</a>
      </div>
      <div class="hero-meta">
        <span><span class="dot ok"></span> All systems operational</span>
        <span class="sep">·</span>
        <span>2 models in catalog</span>
        <span class="sep">·</span>
        <span>128K context</span>
      </div>
    </div>
  </section>

  {/* Feature grid */}
  <FeatureGrid
    eyebrow="Why Ultralisk"
    heading="Inference that respects your stack and your budget."
    subheading="Built by infrastructure engineers who got tired of black-box inference clouds. Three principles guide every decision."
    features={features}
  />

  {/* Zealot callout — the engine underneath */}
  <section class="section zealot-callout">
    <div class="container">
      <div class="zealot-grid">
        <div class="zealot-copy">
          <span class="eyebrow">The engine</span>
          <h2>Zealot — built so we can see every token.</h2>
          <p class="muted">
            We didn't fork an upstream engine. Zealot is our own Rust + CUDA
            inference engine — Block Manager, Constrained Decode, and Scheduler
            all written so the hot path has no interpreter and no GIL.
            Default backend by Phase 3, with a public benchmark target of
            80%+ of Together TIE.
          </p>
          <ul class="bullets muted">
            <li>Memory-safe Block Manager — stale handles return <code>Err</code>, not corrupted KV cache</li>
            <li>Compiled-DFA constrained decode — roughly 10× faster than Python outlines on schema traffic</li>
            <li>Rust scheduler with OOM preemption — no GC pauses leaking into p99</li>
            <li>Custom CUDA attention kernels for Llama-family models</li>
          </ul>
          <a href="/zealot" class="btn btn-secondary btn-lg zealot-cta">
            Inside Zealot
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
        </div>
        <aside class="zealot-bench card">
          <header>
            <h3>Public benchmark target</h3>
            <span class="muted">Llama 3.1 workload · M12</span>
          </header>
          <div class="bench-row">
            <span class="bench-label">Together TIE</span>
            <span class="bench-bar"><span class="bench-fill ref" style="width: 100%"></span></span>
            <span class="bench-value muted">100%</span>
          </div>
          <div class="bench-row">
            <span class="bench-label">vLLM vanilla</span>
            <span class="bench-bar"><span class="bench-fill" style="width: 55%"></span></span>
            <span class="bench-value muted">~55%</span>
          </div>
          <div class="bench-row">
            <span class="bench-label">Zealot 1.0</span>
            <span class="bench-bar"><span class="bench-fill zealot" style="width: 80%"></span></span>
            <span class="bench-value">≥80%</span>
          </div>
          <p class="footnote subtle">
            Target measured against Together's published Llama 3.1 throughput
            numbers on H100. Numbers will be reproduced at M3.3 with methodology
            published alongside.
          </p>
        </aside>
      </div>
    </div>
  </section>

  {/* Platform callout — the operations console */}
  <section class="section platform-callout">
    <div class="container">
      <div class="platform-grid">
        <aside class="platform-mockup card">
          <header class="mockup-head">
            <span class="dot-cluster"><span /><span /><span /></span>
            <span class="mockup-title">console.ultralisk.io/gpu-utilization</span>
            <span class="mockup-tag">Phase 2</span>
          </header>
          <div class="mockup-body">
            <h3 class="mockup-h">GPU Utilization · last 24h</h3>
            <div class="cards-row">
              <div class="kpi">
                <span class="kpi-label">Avg</span>
                <span class="kpi-value">68%</span>
              </div>
              <div class="kpi">
                <span class="kpi-label">GPUs</span>
                <span class="kpi-value">312 / 384</span>
              </div>
              <div class="kpi">
                <span class="kpi-label">Idle</span>
                <span class="kpi-value warn">72</span>
              </div>
            </div>
            <svg class="chart-svg" viewBox="0 0 600 100" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <linearGradient id="p-llama" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#7c3aed" stop-opacity="0.5"/>
                  <stop offset="100%" stop-color="#7c3aed" stop-opacity="0"/>
                </linearGradient>
                <linearGradient id="p-8b" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.5"/>
                  <stop offset="100%" stop-color="#22d3ee" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M 0 60 L 60 50 L 120 45 L 180 30 L 240 35 L 300 20 L 360 25 L 420 18 L 480 30 L 540 25 L 600 35 L 600 100 L 0 100 Z" fill="url(#p-llama)"/>
              <path d="M 0 60 L 60 50 L 120 45 L 180 30 L 240 35 L 300 20 L 360 25 L 420 18 L 480 30 L 540 25 L 600 35" stroke="#a78bfa" stroke-width="2" fill="none"/>
              <path d="M 0 80 L 60 75 L 120 78 L 180 70 L 240 68 L 300 65 L 360 70 L 420 65 L 480 72 L 540 68 L 600 75 L 600 100 L 0 100 Z" fill="url(#p-8b)"/>
              <path d="M 0 80 L 60 75 L 120 78 L 180 70 L 240 68 L 300 65 L 360 70 L 420 65 L 480 72 L 540 68 L 600 75" stroke="#22d3ee" stroke-width="2" fill="none"/>
            </svg>
            <div class="breakdown">
              <span class="breakdown-label muted">By model</span>
              <div class="breakdown-bar">
                <span class="bb-seg" style="width:62%; background: linear-gradient(90deg, #7c3aed, #a78bfa);"></span>
                <span class="bb-seg" style="width:22%; background: linear-gradient(90deg, #22d3ee, #67e8f9);"></span>
                <span class="bb-seg" style="width:16%; background: #3f3f46;"></span>
              </div>
            </div>
          </div>
        </aside>

        <div class="platform-copy">
          <span class="eyebrow">The platform</span>
          <h2>Not just an API. A console your SRE will actually use.</h2>
          <p class="muted">
            Inference is the easy part. Knowing what your fleet is doing — who
            is spending what, where the next bottleneck lives — is where teams
            lose weekends. Ultralisk ships the Operations surface that comes
            with running your own GPU cluster, without having to run one.
          </p>
          <ul class="bullets muted">
            <li><strong>GPU Utilization</strong> — real utilization per cluster, model, tenant (not what the scheduler reports)</li>
            <li><strong>Cost Analytics</strong> — spend by model, endpoint, API key, team, project</li>
            <li><strong>Incidents</strong> — p99 spikes, OOM events, evictions, surfaced to Slack / PagerDuty</li>
            <li><strong>Multi-tenancy</strong> — Organization → Project → Resource with RBAC at every boundary</li>
            <li><strong>Private deployment</strong> — same Console on your data center, no Ultralisk telemetry leaves (Phase 3)</li>
          </ul>
          <a href="/platform" class="btn btn-secondary btn-lg platform-cta">
            See the platform
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Model preview strip */}
  <section class="section-tight">
    <div class="container">
      <div class="strip-header">
        <div>
          <span class="eyebrow">Available now</span>
          <h2>Phase 1 catalog</h2>
        </div>
        <a href="/models" class="strip-link">
          Browse all models
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
      </div>
      <div class="model-strip">
        {AVAILABLE_MODELS.map((m) => <ModelCard model={m} compact />)}
      </div>
    </div>
  </section>

  {/* Code example */}
  <section class="section">
    <div class="container">
      <div class="code-section">
        <div class="code-copy">
          <span class="eyebrow">Drop-in replacement</span>
          <h2>The same SDK.<br />One base URL away.</h2>
          <p class="muted">
            Point any OpenAI client at <code>api.ultralisk.io/v1</code> and ship.
            Streaming, function calling, JSON mode — all preserved.
          </p>
          <ul class="bullets muted">
            <li>OpenAI Python / Node SDK — works unchanged</li>
            <li>Streaming via SSE</li>
            <li>Per-request cost preview</li>
          </ul>
          <a href="/docs" class="strip-link">
            Full quickstart
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
        </div>
        <div class="code-area">
          <CodeBlock
            tabs={[
              { label: 'cURL', language: 'bash', code: apiExamples.curl },
              { label: 'Python', language: 'python', code: apiExamples.python },
              { label: 'Streaming', language: 'python', code: apiExamples.streaming },
            ]}
            filename="chat.py"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Latest updates */}
  <section class="section updates-section">
    <div class="container">
      <header class="updates-header">
        <div>
          <span class="eyebrow">Latest updates</span>
          <h2>What we shipped recently.</h2>
        </div>
        <a href="/changelog" class="updates-link">
          All changelog entries
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
      </header>
      <div class="updates-grid">
        {
          latestUpdates.map((e) => (
            <a href={`/changelog/${e.id}`} class="update-card card">
              <header>
                <time datetime={e.data.date.toISOString()} class="muted">
                  {e.data.date.toLocaleDateString(SITE.locale, { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {e.data.phase && <span class="phase-pill">Phase {e.data.phase}</span>}
              </header>
              <h3>{e.data.title}</h3>
              <p class="muted">{e.data.summary}</p>
              <ul class="tags" aria-label="Tags">
                {e.data.tags.map((t) => (
                  <li class={`tag tag-${t}`}>{t}</li>
                ))}
              </ul>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <CTA
    heading="Ready to ship with Ultralisk?"
    body="We're onboarding design partners during Phase 1. Tell us what you're building and we'll send you an API key."
    primary={{ href: '/contact', label: 'Request access' }}
    secondary={{ href: '/pricing', label: 'See pricing' }}
  />
</PageLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding-block: clamp(4rem, 12vw, 8rem);
    overflow: hidden;
    isolation: isolate;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: var(--gradient-glow);
    z-index: -1;
    pointer-events: none;
  }

  .hero-inner {
    text-align: center;
    max-width: 56rem;
    margin-inline: auto;
  }

  .badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-strong);
    color: var(--color-fg);
  }

  .hero-title {
    margin-top: var(--space-5);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tighter);
    font-weight: 700;
  }

  .hero-sub {
    margin-top: var(--space-6);
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    max-width: 56ch;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-8);
  }

  .hero-meta {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: var(--color-fg-subtle);
  }

  .hero-meta .sep {
    color: var(--color-border-strong);
  }

  .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 0.4rem;
    vertical-align: middle;
  }

  .dot.ok {
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
  }

  /* Model strip */
  .strip-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .strip-header h2 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }

  .strip-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  .strip-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .model-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  /* Code section */
  .code-section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-12);
    align-items: center;
  }

  /* Grid items default to min-width:auto — let them shrink so the
     code block's scrollable pre doesn't blow out the page width */
  .code-section > * {
    min-width: 0;
  }

  @media (max-width: 880px) {
    .code-section {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .code-copy h2 {
    margin-top: var(--space-3);
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    line-height: 1.1;
  }

  .code-copy p {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .code-copy code {
    background: var(--color-bg-code);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .bullets {
    list-style: none;
    margin-top: var(--space-5);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .bullets li::before {
    content: '→';
    color: var(--color-accent);
    margin-right: 0.5rem;
    font-weight: 600;
  }

  .code-copy .strip-link {
    margin-top: var(--space-6);
    display: inline-flex;
  }

  /* Zealot callout */
  .zealot-callout {
    background: var(--color-bg-elevated);
    border-block: 1px solid var(--color-border);
  }

  .zealot-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .zealot-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .zealot-copy h2 {
    margin-top: var(--space-3);
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    max-width: 20ch;
  }

  .zealot-copy > p {
    margin-top: var(--space-5);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
  }

  .zealot-copy .bullets {
    margin-top: var(--space-6);
    max-width: 60ch;
  }

  .zealot-copy .bullets code {
    background: var(--color-bg-code);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.92em;
  }

  .zealot-cta {
    margin-top: var(--space-6);
    display: inline-flex;
  }

  /* Benchmark card */
  .zealot-bench {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .zealot-bench header {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .zealot-bench h3 {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .zealot-bench header .muted {
    font-size: var(--text-xs);
  }

  .bench-row {
    display: grid;
    grid-template-columns: 110px 1fr 48px;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
  }

  .bench-label {
    color: var(--color-fg-muted);
    font-weight: 500;
  }

  .bench-bar {
    height: 6px;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .bench-fill {
    display: block;
    height: 100%;
    background: var(--color-border-strong);
    border-radius: var(--radius-full);
  }

  .bench-fill.ref {
    background: var(--color-border-strong);
  }

  .bench-fill.zealot {
    background: var(--gradient-brand);
  }

  .bench-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .zealot-bench .footnote {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    max-width: 36ch;
  }

  /* Platform callout (mirrors Zealot section structure) */
  .platform-callout {
    background: var(--color-bg);
    border-block: 1px solid var(--color-border);
  }

  .platform-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (max-width: 1024px) {
    .platform-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .platform-copy h2 {
    margin-top: var(--space-3);
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    max-width: 22ch;
  }

  .platform-copy > p {
    margin-top: var(--space-5);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
  }

  .platform-copy .bullets {
    margin-top: var(--space-6);
    max-width: 60ch;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .platform-copy .bullets strong {
    color: var(--color-fg);
    font-weight: 600;
  }

  .platform-cta {
    margin-top: var(--space-6);
    display: inline-flex;
  }

  /* Platform mockup card */
  .platform-mockup {
    padding: 0;
    overflow: hidden;
  }

