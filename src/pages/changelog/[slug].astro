---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '~/consts';

export async function getStaticPaths() {
  const entries = await getCollection('changelog');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, all: entries },
  }));
}

const { entry, all } = Astro.props;
const { Content } = await render(entry);

// Adjacent navigation: previous (older) and next (newer)
const sorted = [...all].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const idx = sorted.findIndex((e) => e.id === entry.id);
const older = idx > 0 ? sorted[idx - 1] : null;
const newer = idx < sorted.length - 1 ? sorted[idx + 1] : null;

const tagLabel = (t: string) =>
  ({ added: 'Added', improved: 'Improved', fixed: 'Fixed', deprecated: 'Deprecated', security: 'Security' })[t] ?? t;
---

<PageLayout
  title={entry.data.title}
  description={entry.data.summary}
>
  <section class="section">
    <div class="container container-narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/changelog">Changelog</a>
        <span aria-hidden="true">/</span>
        <time datetime={entry.data.date.toISOString()} class="muted">
          {entry.data.date.toLocaleDateString(SITE.locale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </nav>

      <article class="entry-detail">
        <header>
          {entry.data.phase && <span class="phase-pill">Phase {entry.data.phase}</span>}
          <h1>{entry.data.title}</h1>
          <p class="summary muted">{entry.data.summary}</p>
          <ul class="tags" aria-label="Tags">
            {entry.data.tags.map((t) => (
              <li class={`tag tag-${t}`}>{tagLabel(t)}</li>
            ))}
          </ul>
        </header>

        <div class="prose">
          <Content />
        </div>
      </article>

      <nav class="adjacent" aria-label="Adjacent entries">
        {
          older ? (
            <a href={`/changelog/${older.id}`} class="adjacent-link prev">
              <span class="adjacent-label muted">Older</span>
              <span class="adjacent-title">{older.data.title}</span>
              <time datetime={older.data.date.toISOString()} class="muted">
                {older.data.date.toLocaleDateString(SITE.locale, { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          ) : (
            <span />
          )
        }
        {
          newer ? (
            <a href={`/changelog/${newer.id}`} class="adjacent-link next">
              <span class="adjacent-label muted">Newer</span>
              <span class="adjacent-title">{newer.data.title}</span>
              <time datetime={newer.data.date.toISOString()} class="muted">
                {newer.data.date.toLocaleDateString(SITE.locale, { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </div>
  </section>
</PageLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-fg-subtle);
    margin-bottom: var(--space-6);
  }

  .breadcrumb a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .entry-detail header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .entry-detail h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: var(--tracking-tighter);
    line-height: 1.1;
  }

  .entry-detail .summary {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .phase-pill {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    background: var(--color-bg-subtle);
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: var(--space-5);
  }

  .tag {
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .tag-added {
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
  }

  .tag-improved {
    background: rgba(34, 211, 238, 0.12);
    color: var(--color-accent);
  }

  [data-theme='light'] .tag-improved {
    color: var(--color-accent-2);
  }

  .tag-fixed {
    background: rgba(124, 58, 237, 0.12);
    color: var(--color-accent);
  }

  [data-theme='light'] .tag-fixed {
    color: var(--color-accent-2);
  }

  .tag-deprecated {
    background: rgba(245, 158, 11, 0.12);
    color: #f59e0b;
  }

  .tag-security {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  /* Prose */
  .prose {
    color: var(--color-fg);
    line-height: var(--leading-relaxed);
    font-size: var(--text-base);
  }

  .prose :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-3);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
  }

  .prose :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .prose :global(p) {
    margin-top: var(--space-3);
    max-width: 65ch;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-top: var(--space-3);
    padding-left: var(--space-6);
    max-width: 65ch;
  }

  .prose :global(li) {
    margin-top: var(--space-1);
  }

  .prose :global(table) {
    margin: var(--space-5) 0;
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .prose :global(th) {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-subtle);
    font-weight: 600;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(td) {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(code) {
    background: var(--color-bg-code);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .prose :global(pre) {
    margin: var(--space-4) 0;
    padding: var(--space-5);
    background: var(--color-bg-code);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-size: var(--text-sm);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Adjacent */
  .adjacent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 600px) {
    .adjacent {
      grid-template-columns: 1fr;
    }
  }

  .adjacent-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-elevated);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .adjacent-link:hover {
    border-color: var(--color-border-strong);
  }

  .adjacent-link.next {
    text-align: right;
  }

  .adjacent-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: 600;
  }

  .adjacent-title {
    font-weight: 600;
    color: var(--color-fg);
    line-height: var(--leading-snug);
  }

  .adjacent-link time {
    font-size: var(--text-xs);
  }
</style>