---
import PageLayout from '~/layouts/PageLayout.astro';
import { SITE } from '~/consts';
---

<PageLayout
  title="Terms"
  description="Ultralisk website terms of use."
>
  <section class="section">
    <div class="container container-narrow">
      <header class="page-header">
        <span class="eyebrow">Legal</span>
        <h1>Terms of use</h1>
        <p class="updated muted">Last updated: Phase 1 launch.</p>
      </header>

      <div class="prose">
        <p>
          These terms govern your use of the Ultralisk public website. Use
          of the Ultralisk Console and inference APIs is governed by a
          separate service agreement presented at signup.
        </p>
        <h2>Acceptable use</h2>
        <p>
          The website and its content are provided for informational
          purposes. You agree not to scrape, mirror, or otherwise reproduce
          the site for commercial purposes without prior written consent.
        </p>
        <h2>No warranty</h2>
        <p>
          Information on this site is provided "as is" without warranty of
          any kind. Pricing and feature availability are subject to change.
        </p>
        <h2>Contact</h2>
        <p>
          Questions about these terms can be sent to{' '}
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .page-header {
    margin-bottom: var(--space-10);
  }

  .page-header h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: var(--tracking-tighter);
  }

  .updated {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
  }

  .prose {
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }

  .prose h2 {
    color: var(--color-fg);
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    letter-spacing: var(--tracking-tight);
  }

  .prose p {
    margin-bottom: var(--space-4);
    max-width: 65ch;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>