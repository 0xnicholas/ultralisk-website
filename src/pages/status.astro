---
import PageLayout from '~/layouts/PageLayout.astro';
import UptimeBar from '~/components/UptimeBar.astro';
import { SITE } from '~/consts';
import {
  SERVICES,
  ACTIVE_INCIDENTS,
  PAST_INCIDENTS,
  UPTIME_HISTORY,
  overallStatus,
  STATUS_META,
} from '~/data/status';

const overall = overallStatus(SERVICES);
const lastUpdated = new Date().toISOString();
const layerOrder = ['inference', 'platform', 'infrastructure'] as const;
const layerLabels = {
  inference: 'Inference API',
  platform: 'Console',
  infrastructure: 'Infrastructure',
};
---

<PageLayout
  title="Status"
  description="Real-time and historical status for Ultralisk services: API, Console, Gateway, and inference engine."
>
  {/* Hero banner */}
  <section class={`banner banner-${overall.status}`}>
    <div class="container banner-inner">
      <span class={`status-pill pill-${overall.status}`}>
        <span class="pulse" aria-hidden="true"></span>
        {STATUS_META[overall.status].label}
      </span>
      <h1 class="banner-title">{overall.label}</h1>
      <p class="banner-desc muted">{overall.description}</p>
      <p class="banner-meta">
        <span class="muted">Last updated</span>
        <time datetime={lastUpdated} class="mono">{lastUpdated.replace('T', ' ').slice(0, 16)} UTC</time>
        <span class="muted">·</span>
        <a href="#subscribe" class="subscribe-link">Subscribe to updates</a>
      </p>
    </div>
  </section>

  {/* Active incidents */}
  {
    ACTIVE_INCIDENTS.length > 0 && (
      <section class="section section-active">
        <div class="container container-narrow">
          <header class="section-header">
            <span class="eyebrow eyebrow-alert">Active incidents</span>
            <h2>Ongoing issues</h2>
          </header>
          <div class="incidents">
            {ACTIVE_INCIDENTS.map((inc) => (
              <article class="incident incident-active">
                <header>
                  <span class={`sev sev-${inc.severity}`}>{inc.severity}</span>
                  <h3>{inc.title}</h3>
                  <span class={`status-tag tag-${inc.status}`}>{inc.status}</span>
                </header>
                <p class="muted incident-affects">
                  Affecting: {inc.affectedServices.map((id) => SERVICES.find((s) => s.id === id)?.name).filter(Boolean).join(', ')}
                </p>
                <ol class="updates">
                  {inc.updates.map((u) => (
                    <li class="update">
                      <div class="update-meta">
                        <time datetime={u.at} class="mono">{u.at.replace('T', ' ').slice(0, 16)} UTC</time>
                        <span class={`status-tag tag-${u.status}`}>{u.status}</span>
                      </div>
                      <p>{u.body}</p>
                    </li>
                  ))}
                </ol>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* Services + uptime bars */}
  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Services</span>
        <h2>By component.</h2>
        <p class="muted lede">
          Real-time status for every service we run. The bars below show the
          last 90 days; hover any day for detail.
        </p>
      </header>

      <div class="layers">
        {
          layerOrder.map((layer) => {
            const services = SERVICES.filter((s) => s.layer === layer);
            if (services.length === 0) return null;
            return (
              <div class="layer">
                <h3 class="layer-title">{layerLabels[layer]}</h3>
                <ul class="services">
                  {services.map((s) => (
                    <li class="service">
                      <div class="service-head">
                        <div class="service-info">
                          <span class={`status-dot dot-${s.status}`} aria-label={STATUS_META[s.status].label} />
                          <div>
                            <h4>{s.name}</h4>
                            <p class="muted">{s.description}</p>
                          </div>
                        </div>
                        <span class={`status-tag tag-${s.status}`}>{STATUS_META[s.status].label}</span>
                      </div>
                      <UptimeBar days={UPTIME_HISTORY[s.id] ?? []} />
                    </li>
                  ))}
                </ul>
              </div>
            );
          })
        }
      </div>

      <div class="legend">
        <span class="legend-title muted">Legend:</span>
        {
          (['operational', 'degraded', 'outage', 'maintenance'] as const).map((s) => (
            <span class="legend-item">
              <span class={`upday upday-${s}`} aria-hidden="true" />
              <span>{STATUS_META[s].label}</span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  {/* Past incidents */}
  {
    PAST_INCIDENTS.length > 0 && (
      <section class="section section-past">
        <div class="container">
          <header class="section-header">
            <span class="eyebrow">Past 90 days</span>
            <h2>Incident history.</h2>
          </header>
          <div class="incidents">
            {PAST_INCIDENTS.map((inc) => (
              <article class="incident incident-past">
                <header>
                  <span class={`sev sev-${inc.severity}`}>{inc.severity}</span>
                  <h3>{inc.title}</h3>
                  <span class="muted mono">
                    {inc.createdAt.slice(0, 10)} → {inc.resolvedAt?.slice(0, 10) ?? 'ongoing'}
                  </span>
                </header>
                <p class="muted incident-affects">
                  Affecting: {inc.affectedServices.map((id) => SERVICES.find((s) => s.id === id)?.name).filter(Boolean).join(', ')}
                </p>
                <details class="incident-details">
                  <summary>Show timeline ({inc.updates.length} updates)</summary>
                  <ol class="updates">
                    {inc.updates.map((u) => (
                      <li class="update">
                        <div class="update-meta">
                          <time datetime={u.at} class="mono">{u.at.replace('T', ' ').slice(0, 16)} UTC</time>
                          <span class={`status-tag tag-${u.status}`}>{u.status}</span>
                        </div>
                        <p>{u.body}</p>
                      </li>
                    ))}
                  </ol>
                </details>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* Subscribe + footer info */}
  <section id="subscribe" class="section subscribe-section">
    <div class="container container-narrow">
      <div class="subscribe-grid">
        <div>
          <h2>Get notified.</h2>
          <p class="muted">
            Subscribe to receive a notification when an incident is filed or
            resolved. No marketing, no newsletter — incidents only.
          </p>
        </div>
        <form class="subscribe-form" action={`mailto:${SITE.email}`} method="post" enctype="text/plain">
          <label for="email" class="sr-only">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="you@company.com"
            required
          />
          <button type="submit" class="btn btn-gradient">Subscribe</button>
        </form>
      </div>
      <p class="subscribe-meta muted">
        We send at most one email per incident — open, update, resolved.
        Coming in Phase 2: RSS feed and Slack / Webhooks integration.
      </p>
    </div>
  </section>
</PageLayout>

<script>
  // Set up realtime updates — for now, just refresh every 60s. When wired to a
  // real status backend, replace this with a Server-Sent Events / WebSocket
  // connection that pushes status changes without a reload.
  setTimeout(() => location.reload(), 60_000);
</script>

<style>
  /* Banner */
  .banner {
    padding-block: clamp(3rem, 8vw, 5rem);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }

  .banner-operational {
    background: linear-gradient(
      180deg,
      rgba(34, 197, 94, 0.12),
      var(--color-bg-elevated) 60%
    );
  }

  .banner-degraded {
    background: linear-gradient(
      180deg,
      rgba(245, 158, 11, 0.12),
      var(--color-bg-elevated) 60%
    );
  }

  .banner-outage {
    background: linear-gradient(
      180deg,
      rgba(239, 68, 68, 0.14),
      var(--color-bg-elevated) 60%
    );
  }

  .banner-maintenance {
    background: linear-gradient(
      180deg,
      rgba(34, 211, 238, 0.12),
      var(--color-bg-elevated) 60%
    );
  }

  .banner-inner {
    text-align: center;
    max-width: 48rem;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
  }

  .pill-operational {
    color: #22c55e;
    border-color: rgba(34, 197, 94, 0.4);
  }

  .pill-degraded {
    color: #f59e0b;
    border-color: rgba(245, 158, 11, 0.4);
  }

  .pill-outage {
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.4);
  }

  .pill-maintenance {
    color: var(--color-cyan-400);
    border-color: rgba(34, 211, 238, 0.4);
  }

  [data-theme='light'] .pill-maintenance {
    color: var(--color-cyan-700);
  }

  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    animation: pulse-glow 2s var(--ease-in-out) infinite;
  }

  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 0 0 currentColor;
      opacity: 1;
    }
    50% {
      box-shadow: 0 0 0 8px transparent;
      opacity: 0.7;
    }
  }

  .banner-title {
    margin-top: var(--space-4);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: var(--tracking-tighter);
    line-height: 1.05;
  }

  .banner-desc {
    margin-top: var(--space-3);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .banner-meta {
    margin-top: var(--space-4);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
    font-size: var(--text-sm);
  }

  .mono {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .subscribe-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Section headers */
  .section-header {
    max-width: 48rem;
    margin-bottom: var(--space-8);
  }

  .section-header h2 {
    margin-top: var(--space-3);
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
  }

  .section-header .lede {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .eyebrow-alert {
    color: #ef4444;
  }

  /* Layers */
  .layers {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .layer-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-subtle);
    margin-bottom: var(--space-4);
  }

  .services {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .service {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg-elevated);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .service-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .service-info {
    display: flex;
    align-items: start;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.5em;
  }

  .dot-operational {
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2);
  }

  .dot-degraded {
    background: #f59e0b;
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
  }

  .dot-outage {
    background: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2);
  }

  .dot-maintenance {
    background: var(--color-cyan-400);
    box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.2);
  }

  [data-theme='light'] .dot-maintenance {
    box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.2);
  }

  .service h4 {
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }

  .service p {
    margin-top: 2px;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  /* Status tags */
  .status-tag {
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    flex-shrink: 0;
  }

  .tag-operational {
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
  }

  .tag-degraded {
    background: rgba(245, 158, 11, 0.12);
    color: #f59e0b;
  }

  .tag-outage {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  .tag-maintenance {
    background: rgba(34, 211, 238, 0.12);
    color: var(--color-cyan-400);
  }

  [data-theme='light'] .tag-maintenance {
    color: var(--color-cyan-700);
  }

  .tag-investigating {
    background: rgba(245, 158, 11, 0.12);
    color: #f59e0b;
  }

  .tag-identified {
    background: rgba(124, 58, 237, 0.12);
    color: var(--color-violet-400);
  }

  [data-theme='light'] .tag-identified {
    color: var(--color-violet-700);
  }

  .tag-monitoring {
    background: rgba(34, 211, 238, 0.12);
    color: var(--color-cyan-400);
  }

  [data-theme='light'] .tag-monitoring {
    color: var(--color-cyan-700);
  }

  .tag-resolved {
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
  }

  /* Legend */
  .legend {
    margin-top: var(--space-10);
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    font-size: var(--text-xs);
  }

  .legend-title {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .legend .upday {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }

  /* Incidents */
  .incidents {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .incident {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg-elevated);
    padding: var(--space-5) var(--space-6);
  }

  .incident-active {
    border-color: rgba(239, 68, 68, 0.4);
    box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.2);
  }

  .incident header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .incident h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    flex: 1;
    min-width: 200px;
  }

  .sev {
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .sev-minor {
    background: rgba(245, 158, 11, 0.12);
    color: #f59e0b;
  }

  .sev-major {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  .sev-critical {
    background: #ef4444;
    color: white;
  }

  .incident-affects {
    font-size: var(--text-sm);
    margin: var(--space-2) 0 var(--space-4);
  }

  .updates {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-5);
  }

  .update {
    position: relative;
  }

  .update::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-5) - 5px);
    top: 0.4em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-bg-elevated);
    border: 2px solid var(--color-fg-subtle);
  }

  .update-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .update p {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .incident-details {
    margin-top: var(--space-3);
  }

  .incident-details summary {
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    list-style: none;
  }

  .incident-details summary::-webkit-details-marker {
    display: none;
  }

  .incident-details summary::before {
    content: '▸';
    display: inline-block;
    margin-right: 0.5rem;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .incident-details[open] summary::before {
    transform: rotate(90deg);
  }

  .incident-details .updates {
    margin-top: var(--space-3);
  }

  /* Subscribe */
  .subscribe-section {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
  }

  .subscribe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (max-width: 720px) {
    .subscribe-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }

  .subscribe-grid h2 {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-tight);
  }

  .subscribe-grid p {
    margin-top: var(--space-3);
    line-height: var(--leading-relaxed);
  }

  .subscribe-form {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .subscribe-form input {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-fg);
    font-size: var(--text-base);
    font-family: inherit;
  }

  .subscribe-form input:focus {
    outline: none;
    border-color: var(--color-violet-500);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);
  }

  .subscribe-meta {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>