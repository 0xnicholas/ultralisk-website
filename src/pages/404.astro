---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Logo from '~/components/Logo.astro';
---

<BaseLayout title="Page not found" noindex>
  <main class="notfound">
    <div class="container">
      <Logo variant="default" size={48} />
      <h1>
        <span class="gradient-text">404</span>
      </h1>
      <p class="lede">
        That page is on a different planet.<br />
        Maybe one of these will get you back on course.
      </p>
      <div class="links">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/models" class="btn btn-secondary">Models</a>
        <a href="/pricing" class="btn btn-secondary">Pricing</a>
        <a href="/docs" class="btn btn-secondary">Quickstart</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .notfound {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-block: var(--space-16);
  }

  .container {
    max-width: 32rem;
  }

  h1 {
    margin-top: var(--space-6);
    font-size: clamp(5rem, 20vw, 10rem);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
  }

  .lede {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-8);
  }
</style>