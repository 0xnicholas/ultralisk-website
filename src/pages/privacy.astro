---
import PageLayout from '~/layouts/PageLayout.astro';
import { SITE } from '~/consts';
---

<PageLayout
  title="Privacy"
  description="Ultralisk privacy policy."
>
  <section class="section">
    <div class="container container-narrow">
      <header class="page-header">
        <span class="eyebrow">Legal</span>
        <h1>Privacy</h1>
        <p class="updated muted">Last updated: Phase 1 launch.</p>
      </header>

      <div class="prose">
        <p>
          This is a placeholder privacy policy for the Ultralisk public
          website. The full privacy policy governing your use of the
          Ultralisk Console and inference APIs will be presented to you at
          signup.
        </p>
        <h2>What this site collects</h2>
        <p>
          This marketing site is static. It does not set tracking cookies
          and does not run analytics scripts. Server logs (IP, user-agent,
          request path) are retained by the hosting provider for operational
          purposes and are not used for marketing.
        </p>
        <h2>Contact</h2>
        <p>
          Questions about privacy can be sent to{' '}
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .page-header {
    margin-bottom: var(--space-10);
  }

  .page-header h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: var(--tracking-tighter);
  }

  .updated {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
  }

  .prose {
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }

  .prose h2 {
    color: var(--color-fg);
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    letter-spacing: var(--tracking-tight);
  }

  .prose p {
    margin-bottom: var(--space-4);
    max-width: 65ch;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>